{
  "kind": "dwclayout",
  "app": "FlexibleLayouts",
  "fileVersion": 1,
  "exportedAt": "2026-06-10T00:00:00.000Z",
  "document": {
    "schemaVersion": 1,
    "meta": {
      "name": "Flexible Layouts Example",
