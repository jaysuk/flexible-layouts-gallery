        "kind": "custom",
        "title": "Example Demo",
        "icon": "mdi-puzzle-outline",
        "category": "control",
        "grid": { "cols": 12, "rowHeight": 30 },
        "items": [
          {
            "i": "ex-page",
            "x": 0, "y": 0, "w": 6, "h": 10,
            "title": "Example Page (plugin)",
            "widget": {
              "type": "pluginPage",
              "source": "page",
              "path": "/Plugins/FlexLayoutsExample",
              "pluginId": "FlexLayoutsExample",
              "label": "Example Page"
            }
          },
          {
            "i": "ex-panel",
            "x": 6, "y": 0, "w": 3, "h": 5,
            "title": "Example Panel (plugin)",
            "widget": {
              "type": "pluginPage",
              "source": "page",
              "path": "/Plugins/FlexLayoutsExample/Panel",
              "pluginId": "FlexLayoutsExample",
              "label": "Example Panel"
            }
          },
          {
            "i": "ex-note",
            "x": 9, "y": 0, "w": 3, "h": 5,
            "title": "About this layout",
            "widget": {
              "type": "note",
              "content": "# Flexible Layouts Example\n\nThis layout embeds **both** halves of the *Flexible Layouts Example* plugin:\n\n- the full **page** (left), and\n- the compact **panel** (middle),\n\neach via a *Plugin page* widget. It's also the test case for **dependency-aware import** — without the plugin installed you'll have seen the missing-plugin warning."
            }
          },
          {
            "i": "ex-clock",
            "x": 6, "y": 5, "w": 6, "h": 2,
            "widget": { "type": "clock", "label": "Time", "source": "time" }
          }
        ]
      }
    },
    "nav": { "order": ["/Plugins/FlexibleLayouts/p/example-panel-demo"], "hidden": [] },
    "dependencies": [
      {
        "pluginId": "FlexLayoutsExample",
        "name": "Flexible Layouts Example",
        "reason": "Embeds the plugin's example page and panel on the Example Demo page"
      }
    ]
  }
